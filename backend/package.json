{
  "name": "calcus-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:python": "python3 main.py",
    "seed": "tsx seed.ts",
    "build": "npm run build:server",
    "build:server": "esbuild server.ts --bundle --platform=node --target=node22 --outfile=dist/server.cjs --format=cjs --external:pg-native --external:fsevents --external:vite --external:pg-hstore --external:lightningcss --external:pg --external:sequelize",
    "build:python": "pip install -r requirements.txt",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "install:all": "npm install && pip install -r requirements.txt"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1031.0",
    "@aws-sdk/client-ec2": "^3.1024.0",
    "@aws-sdk/client-eks": "^3.1031.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.1031.0",
    "@aws-sdk/client-lambda": "^3.1031.0",
    "@aws-sdk/client-pricing": "^3.1024.0",
    "@aws-sdk/client-rds": "^3.1031.0",
    "@aws-sdk/client-route-53": "^3.1031.0",
    "@aws-sdk/client-s3": "^3.1031.0",
    "@google/genai": "^1.29.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.1",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.5",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
