{
  "entities": {
    "provider": {
      "title": "Provider",
      "description": "Cloud provider (AWS, Azure, GCP)",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Provider name" }
      },
      "required": ["name"]
    },
    "region": {
      "title": "Region",
      "description": "Cloud provider region",
      "type": "object",
      "properties": {
        "provider_id": { "type": "string", "description": "Provider ID" },
        "region_code": { "type": "string", "description": "Region code (e.g., us-east-1)" },
        "region_name": { "type": "string", "description": "Region display name" }
      },
      "required": ["provider_id", "region_code", "region_name"]
    },
    "compute_pricing": {
      "title": "Compute Pricing",
      "description": "Pricing for compute instances",
      "type": "object",
      "properties": {
        "provider_id": { "type": "string" },
        "region_id": { "type": "string" },
        "instance_type": { "type": "string" },
        "os_type": { "type": "string", "enum": ["Linux", "Windows"] },
        "price_per_hour": { "type": "number" },
        "price_per_month": { "type": "number" },
        "price_per_year": { "type": "number" },
        "vcpu": { "type": "number" },
        "memory_gb": { "type": "number" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["provider_id", "region_id", "instance_type", "os_type", "price_per_hour", "vcpu", "memory_gb"]
    },
    "storage_pricing": {
      "title": "Storage Pricing",
      "description": "Pricing for storage services",
      "type": "object",
      "properties": {
        "provider_id": { "type": "string" },
        "region_id": { "type": "string" },
        "storage_type": { "type": "string", "enum": ["block", "object", "file", "archive"] },
        "storage_name": { "type": "string" },
        "price_per_gb_month": { "type": "number" },
        "iops_price": { "type": "number" },
        "throughput_price": { "type": "number" },
        "unit_type": { "type": "string" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["provider_id", "region_id", "storage_type", "storage_name", "price_per_gb_month"]
    },
    "database_pricing": {
      "title": "Database Pricing",
      "description": "Pricing for managed database services",
      "type": "object",
      "properties": {
        "provider_id": { "type": "string" },
        "region_id": { "type": "string" },
        "db_engine": { "type": "string", "enum": ["MySQL", "PostgreSQL", "SQL Server", "Oracle", "MongoDB", "Redis"] },
        "instance_class": { "type": "string" },
        "deployment_option": { "type": "string", "enum": ["Single-AZ", "Multi-AZ"] },
        "price_per_hour": { "type": "number" },
        "vcpu": { "type": "number" },
        "memory_gb": { "type": "number" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["provider_id", "region_id", "db_engine", "instance_class", "price_per_hour"]
    },
    "networking_pricing": {
      "title": "Networking Pricing",
      "description": "Pricing for networking services (Data Transfer, Load Balancers)",
      "type": "object",
      "properties": {
        "provider_id": { "type": "string" },
        "region_id": { "type": "string" },
        "service_type": { "type": "string", "enum": ["Data Transfer Out", "Load Balancer", "VPN", "Direct Connect"] },
        "price_per_unit": { "type": "number" },
        "unit": { "type": "string" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["provider_id", "region_id", "service_type", "price_per_unit", "unit"]
    },
    "calculation": {
      "title": "Calculation",
      "description": "Saved pricing calculation",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "input_json": { "type": "object" },
        "result_json": { "type": "object" },
        "cheapest_provider": { "type": "string" },
        "aws_total_monthly": { "type": "number" },
        "azure_total_monthly": { "type": "number" },
        "gcp_total_monthly": { "type": "number" },
        "duration_months": { "type": "integer" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "input_json", "result_json", "duration_months", "created_at"]
    },
    "audit_log": {
      "title": "Audit Log",
      "description": "System audit log",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "action": { "type": "string" },
        "input_data": { "type": "object" },
        "status": { "type": "string" },
        "error_message": { "type": "string" },
        "ip_address": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["action", "status", "timestamp"]
    }
  },
  "firestore": {
    "/providers": { "schema": "provider", "description": "Cloud providers" },
    "/regions": { "schema": "region", "description": "Cloud regions" },
    "/compute_pricing": { "schema": "compute_pricing", "description": "Instance pricing" },
    "/storage_pricing": { "schema": "storage_pricing", "description": "Storage pricing" },
    "/database_pricing": { "schema": "database_pricing", "description": "Database pricing" },
    "/networking_pricing": { "schema": "networking_pricing", "description": "Networking pricing" },
    "/calculations": { "schema": "calculation", "description": "Saved calculations" },
    "/audit_logs": { "schema": "audit_log", "description": "System audit logs" },
    "/users": { "schema": "user", "description": "User profiles" }
  }
}
